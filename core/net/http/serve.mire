module serve
pub fn file: (fd :i64, file_path :&str) {
    set fp = *file_path
    if fs::exists(fp) {
        set data = fs::read(fp)
        set ct = http::server::mime(fp)
        set resp = http::resp::success(data ct)
        net::send(fd resp)
    } else {
        net::send(fd http::resp::not_found())
    }
}

load kioto

@[test]
pub fn test_async_ready: () :bool {
    set t = async::ready("done")
    return async::is_done(t)
}

@[test]
pub fn test_async_failed: () :bool {
    set t = async::failed("error")
    return async::is_error(t)
}

@[test]
pub fn test_async_pending: () :bool {
    return async::is_pending(async::pending())
}

@[test]
pub fn test_async_channel: () :bool {
    set ch = async::channel()
    set l = strings::len(ch)
    return l > 15
}

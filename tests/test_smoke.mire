/// kioto smoke tests
/// Each test returns :bool — true = PASS, false = FAIL

load kioto

@[test]
pub fn test_strings_basic: () :bool {
    set s = strings::len("hello")
    return s == 5
}

@[test]
pub fn test_strings_concat: () :bool {
    set s = "hello " + "world"
    set l = strings::len(s)
    return l == 11
}

@[test]
pub fn test_strings_substr_literal: () :bool {
    set s = strings::substr("hello" 1 3)
    return s == "ell"
}

@[test]
pub fn test_strings_split: () :bool {
    set parts = strings::split("a|b|c" "|")
    set n = lists::len(parts)
    return n == 3
}

@[test]
pub fn test_strings_join: () :bool {
    set parts = strings::split("a|b|c" "|")
    set joined = strings::join(parts ",")
    return joined == "a,b,c"
}

@[test]
pub fn test_lists_basic: () :bool {
    set lst = [1 2 3] :vec[i64]
    set n = lists::len(lst)
    return n == 3
}

@[test]
pub fn test_math_abs: () :bool {
    set n = math::abs(-42)
    return n == 42
}

@[test]
pub fn test_math_min: () :bool {
    set n = math::min(10 20)
    return n == 10
}

@[test]
pub fn test_log: () :bool {
    log::info("smoke-test-run")
    return true
}

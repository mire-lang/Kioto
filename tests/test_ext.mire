/// kioto extended modules smoke tests
/// Each test returns :bool — true = PASS, false = FAIL

load kioto

@[test]
pub fn test_maybe_some_none: () :bool {
    set m = maybe::some("hello")
    return maybe::is_some(m)
}

@[test]
pub fn test_maybe_none: () :bool {
    set m = maybe::none()
    return maybe::is_none(m)
}

@[test]
pub fn test_result_ok: () :bool {
    set r = result::ok("success")
    return result::is_ok(r)
}

@[test]
pub fn test_result_err: () :bool {
    set r = result::err("failure")
    return result::is_err(r)
}

@[test]
pub fn test_iter_count: () :bool {
    set parts = strings::split("a|b|c" "|")
    set n = iter::count(parts)
    return n == 3
}

@[test]
pub fn test_iter_first: () :bool {
    set parts = strings::split("a|b|c" "|")
    set f = iter::first(parts)
    return f == "a"
}

@[test]
pub fn test_iter_last: () :bool {
    set parts = strings::split("a|b|c" "|")
    set l = iter::last(parts)
    return l == "c"
}

@[test]
pub fn test_iter_nth: () :bool {
    set parts = strings::split("a|b|c" "|")
    set el = iter::nth(parts 1)
    return el == "b"
}

@[test]
pub fn test_iter_contains: () :bool {
    set parts = strings::split("a|b|c" "|")
    return iter::contains(parts "b")
}

@[test]
pub fn test_json_is_valid: () :bool {
    return json::is_valid("{\"a\":1}")
}

@[test]
pub fn test_json_escape: () :bool {
    set e = json::escape("hello \"world\"")
    return strings::contains(e "\\\"")
}

@[test]
pub fn test_json_unescape: () :bool {
    set u = json::unescape("hello \\\"world\\\"")
    return strings::contains(u "\"")
}

@[test]
pub fn test_async_ready: () :bool {
    set t = async::ready("done")
    return async::is_done(t)
}

@[test]
pub fn test_async_failed: () :bool {
    set t = async::failed("error")
    return async::is_error(t)
}

@[test]
pub fn test_async_pending: () :bool {
    return async::is_pending(async::pending())
}

@[test]
pub fn test_fs_tmp: () :bool {
    set tmpdir = "/tmp"
    return fs::exists(tmpdir)
}

@[test]
pub fn test_env_home: () :bool {
    set home = env::get("HOME")
    set l = strings::len(home)
    return l > 0
}

@[test]
pub fn test_mem_used: () :bool {
    set u = mem::used()
    return u > 0
}

@[test]
pub fn test_types_is_str: () :bool {
    return types::is_str("hello")
}

@[test]
pub fn test_types_is_int: () :bool {
    return types::is_int(42)
}

@[test]
pub fn test_types_is_bool: () :bool {
    return types::is_bool(true)
}

@[test]
pub fn test_triple: () :bool {
    set t = tuple::triple("a" "b" "c")
    set f = tuple::first(t)
    return f == "a"
}

@[test]
pub fn test_pair: () :bool {
    set t = tuple::pair("x" "y")
    set s = tuple::second(t)
    return s == "y"
}

@[test]
pub fn test_iter_range: () :bool {
    set r = iter::range(0 3)
    // range(0,3) = "0\n1\n2"
    set parts = strings::split(r "\n")
    set n = iter::count(parts)
    return n == 3
}

@[test]
pub fn test_iter_is_empty: () :bool {
    set parts = strings::split("" ",")
    return iter::is_empty(parts)
}

@[test]
pub fn test_iter_index_of: () :bool {
    set parts = strings::split("a|b|c" "|")
    set idx = iter::index_of(parts "b")
    return idx == 1
}

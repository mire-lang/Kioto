/// Bitwise operator tests (requires compiler support for ^ & | << >>)
/// Each test returns :bool — true = PASS, false = FAIL

load kioto

@[test]
pub fn test_bitwise_and: () :bool {
    return (0xFF & 0x0F) == 0x0F
}

@[test]
pub fn test_bitwise_or: () :bool {
    return (0xF0 | 0x0F) == 0xFF
}

@[test]
pub fn test_bitwise_xor: () :bool {
    return (0xFF ^ 0x0F) == 0xF0
}

@[test]
pub fn test_bitwise_shl: () :bool {
    return (1 << 3) == 8
}

@[test]
pub fn test_bitwise_shr: () :bool {
    return (0xFF >> 4) == 0x0F
}

@[test]
pub fn test_bitwise_chained: () :bool {
    set a = 0xFF
    set b = 0x0F
    set c = (a & b) | 0xF0
    return c == 0xFF
}

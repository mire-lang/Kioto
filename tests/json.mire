load kioto

@[test]
pub fn test_json_is_valid: () :bool {
    return json::is_valid("{\"a\":1}")
}

@[test]
pub fn test_json_escape: () :bool {
    set e = json::escape("hello \"world\"")
    return strings::contains(e "\\\"")
}

@[test]
pub fn test_json_unescape: () :bool {
    set u = json::unescape("hello \\\"world\\\"")
    return strings::contains(u "\"")
}

load kioto

@[test]
pub fn test_math_complex_new: () :bool {
    set z = math::complex::new(1.0 2.0)
    set r = math::complex::real(z)
    set i = math::complex::imag(z)
    return r == 1.0 && i == 2.0
}

@[test]
pub fn test_math_complex_add: () :bool {
    set a = math::complex::new(1.0 2.0)
    set b = math::complex::new(3.0 4.0)
    set c = math::complex::add(a b)
    set r = math::complex::real(c)
    set i = math::complex::imag(c)
    return r == 4.0 && i == 6.0
}

@[test]
pub fn test_math_complex_conj: () :bool {
    set z = math::complex::new(1.0 2.0)
    set c = math::complex::conj(z)
    set r = math::complex::real(c)
    set i = math::complex::imag(c)
    return r == 1.0 && i == -2.0
}

@[test]
pub fn test_math_complex_to_str: () :bool {
    set z1 = math::complex::new(3.0 4.0)
    set s1 = math::complex::text(z1)
    return strings::len(s1) > 0
}

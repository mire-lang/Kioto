/// SHA-256 test vectors (from NIST / FIPS 180-4)
/// Each test returns :bool — true = PASS, false = FAIL

load kioto

@[test]
pub fn test_sha256_empty: () :bool {
    set h = crypto::hash::sha256("")
    return h == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
}

@[test]
pub fn test_sha256_abc: () :bool {
    set h = crypto::hash::sha256("abc")
    return h == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
}

@[test]
pub fn test_sha256_hello: () :bool {
    set h = crypto::hash::sha256("hello world")
    return h == "b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9"
}

@[test]
pub fn test_sha256_empty_str: () :bool {
    set h = crypto::hash::sha256("")
    return strings::len(h) == 64
}

@[test]
pub fn test_sha256_hex: () :bool {
    // hash of "abc" should match known hex value
    set h = crypto::hash::sha256("abc")
    set expected = "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
    set matched = h == expected
    if !matched {
        log::info("SHA-256(\"abc\") got: " + h)
        log::info("expected: " + expected)
    }
    return matched
}

@[test]
pub fn test_base64_encode_empty: () :bool {
    set bytes = [] :vec[i64]
    set b64 = crypto::encode::base64::encode(bytes)
    return b64 == ""
}

@[test]
pub fn test_base64_encode_f: () :bool {
    set bytes = [102] :vec[i64]
    set b64 = crypto::encode::base64::encode(bytes)
    return b64 == "Zg=="
}

@[test]
pub fn test_base64_encode_fo: () :bool {
    set bytes = [102 111] :vec[i64]
    set b64 = crypto::encode::base64::encode(bytes)
    return b64 == "Zm8="
}

@[test]
pub fn test_base64_encode_foo: () :bool {
    set bytes = [102 111 111] :vec[i64]
    set b64 = crypto::encode::base64::encode(bytes)
    return b64 == "Zm9v"
}

@[test]
pub fn test_base64_decode_zg: () :bool {
    set bytes = crypto::encode::base64::decode("Zg==")
    set n = lists::len(bytes)
    return n == 1 && lists::get(bytes, 0) == 102
}

@[test]
pub fn test_base64_roundtrip: () :bool {
    set original = [72 101 108 108 111] :vec[i64]
    set encoded = crypto::encode::base64::encode(original)
    set decoded = crypto::encode::base64::decode(encoded)
    set n = lists::len(original)
    set i = 0 :i64 mut
    while i < n {
        if lists::get(decoded, i) != lists::get(original, i) {
            return false
        }
        set i += 1
    }
    return lists::len(decoded) == n
}

@[test]
pub fn test_sha256_deterministic: () :bool {
    set h1 = crypto::hash::sha256("test")
    set h2 = crypto::hash::sha256("test")
    set h3 = crypto::hash::sha256("test")
    return h1 == h2 && h2 == h3
}

@[test]
pub fn test_sha256_avalanche: () :bool {
    set h1 = crypto::hash::sha256("test")
    set h2 = crypto::hash::sha256("Test")
    return h1 != h2
}

@[test]
pub fn test_sha256_nist_multiblock: () :bool {
    set msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
    set h = crypto::hash::sha256(msg)
    return h == "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1"
}

@[test]
pub fn test_sha256_1m_a: () :bool {
    set msg = "" :str mut
    set i = 0 :i64 mut
    while i < 100 {
        set msg = msg + "aaaaaaaaaa"
        set i += 1
    }
    set h = crypto::hash::sha256(msg)
    set len = strings::len(msg)
    return strings::len(h) == 64 && len == 1000
}

@[test]
pub fn test_hex_roundtrip: () :bool {
    set original = [0xDE 0xAD 0xBE 0xEF 0xCA 0xFE] :vec[i64]
    set encoded = crypto::encode::hex::encode(original)
    set decoded = crypto::encode::hex::decode(encoded)
    set n = lists::len(original)
    set i = 0 :i64 mut
    while i < n {
        if lists::get(decoded, i) != lists::get(original, i) {
            return false
        }
        set i += 1
    }
    return lists::len(decoded) == n
}

@[test]
pub fn test_hex_encode_deadbeef: () :bool {
    set bytes = [0xDE 0xAD 0xBE 0xEF] :vec[i64]
    set hex = crypto::encode::hex::encode(bytes)
    return hex == "deadbeef"
}

@[test]
pub fn test_hex_decode_deadbeef: () :bool {
    set bytes = crypto::encode::hex::decode("deadbeef")
    set n = lists::len(bytes)
    if n != 4 { return false }
    set ok = lists::get(bytes, 0) == 0xDE && lists::get(bytes, 1) == 0xAD && lists::get(bytes, 2) == 0xBE && lists::get(bytes, 3) == 0xEF
    return ok
}

@[test]
pub fn test_hex_decode_uppercase: () :bool {
    set bytes = crypto::encode::hex::decode("DEADBEEF")
    set n = lists::len(bytes)
    if n != 4 { return false }
    return lists::get(bytes, 0) == 0xDE && lists::get(bytes, 3) == 0xEF
}

@[test]
pub fn test_base64_rfc4648_vectors: () :bool {
    if crypto::encode::base64::encode([] :vec[i64]) != "" { return false }
    if crypto::encode::base64::encode([102] :vec[i64]) != "Zg==" { return false }
    if crypto::encode::base64::encode([102 111] :vec[i64]) != "Zm8=" { return false }
    if crypto::encode::base64::encode([102 111 111] :vec[i64]) != "Zm9v" { return false }
    if crypto::encode::base64::encode([102 111 111 98] :vec[i64]) != "Zm9vYg==" { return false }
    if crypto::encode::base64::encode([102 111 111 98 97] :vec[i64]) != "Zm9vYmE=" { return false }
    if crypto::encode::base64::encode([102 111 111 98 97 114] :vec[i64]) != "Zm9vYmFy" { return false }
    return true
}

@[test]
pub fn test_base64_decode_rfc4648: () :bool {
    set d0 = crypto::encode::base64::decode("")
    if lists::len(d0) != 0 { return false }
    set d1 = crypto::encode::base64::decode("Zg==")
    if lists::len(d1) != 1 || lists::get(d1, 0) != 102 { return false }
    set d2 = crypto::encode::base64::decode("Zm8=")
    if lists::len(d2) != 2 { return false }
    set d3 = crypto::encode::base64::decode("Zm9v")
    if lists::len(d3) != 3 { return false }
    return true
}

@[test]
pub fn test_crypto_integration: () :bool {
    set msg = "crypto test message"
    set h = crypto::hash::sha256(msg)
    set b64 = crypto::encode::base64::encode([104 101 108 108 111] :vec[i64])
    set hex = crypto::encode::hex::encode([0xAB 0xCD 0xEF] :vec[i64])
    set h_len = strings::len(h)
    set b64_len = strings::len(b64)
    set hex_len = strings::len(hex)
    return h_len == 64 && b64 != "" && hex == "abcdef"
}

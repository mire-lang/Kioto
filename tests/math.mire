load kioto

@[test]
pub fn test_math_abs: () :bool {
    return math::abs(-42) == 42
}

@[test]
pub fn test_math_pi: () :bool {
    set p = math::pi()
    return p > 3.1 && p < 3.2
}

@[test]
pub fn test_math_hypot: () :bool {
    set h = math::hypot(3.0 4.0)
    return h > 4.9 && h < 5.1
}

@[test]
pub fn test_math_random: () :bool {
    set n = math::random::range(0 100)
    return n >= 0 && n < 100
}

@[test]
pub fn test_math_range: () :bool {
    set r = math::range(5)
    set n = lists::len(r)
    return n == 5
}

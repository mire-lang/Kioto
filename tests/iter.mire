load kioto

@[test]
pub fn test_iter_count: () :bool {
    set parts = strings::split("a|b|c" "|")
    set n = iter::count(parts)
    return n == 3
}

@[test]
pub fn test_iter_first: () :bool {
    set parts = strings::split("a|b|c" "|")
    set f = iter::first(parts)
    return f == "a"
}

@[test]
pub fn test_iter_last: () :bool {
    set parts = strings::split("a|b|c" "|")
    set l = iter::last(parts)
    return l == "c"
}

@[test]
pub fn test_iter_nth: () :bool {
    set parts = strings::split("a|b|c" "|")
    set el = iter::nth(parts 1)
    return el == "b"
}

@[test]
pub fn test_iter_contains: () :bool {
    set parts = strings::split("a|b|c" "|")
    return iter::contains(parts "b")
}

@[test]
pub fn test_iter_range: () :bool {
    set r = iter::range(0 3)
    set parts = strings::split(r "\n")
    set n = iter::count(parts)
    return n == 3
}

@[test]
pub fn test_iter_empty: () :bool {
    set parts = strings::split("" ",")
    return iter::empty(parts)
}

@[test]
pub fn test_iter_index: () :bool {
    set parts = strings::split("a|b|c" "|")
    set idx = iter::index(parts "b")
    return idx == 1
}
